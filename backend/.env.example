# ─────────────────────────────────────────────────────────────────────────────
# Island Internship — Backend Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3001
DOMAIN=islandinternship.com

# ─── GoDaddy ──────────────────────────────────────────────────────────────────
# OTE = test environment (safe for experimenting, doesn't affect real DNS)
GODADDY_OTE_KEY=your_ote_key_here
GODADDY_OTE_SECRET=your_ote_secret_here
GODADDY_OTE_BASE_URL=https://api.ote-godaddy.com

# Production (real DNS — be careful)
GODADDY_PROD_KEY=your_prod_key_here
GODADDY_PROD_SECRET=your_prod_secret_here
GODADDY_PROD_BASE_URL=https://api.godaddy.com

# Which environment to use: 'ote' or 'production'
GODADDY_ENV=ote

# ─── Zoho (EU data centre) ───────────────────────────────────────────────────
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here

# Obtained by running: npm run zoho:exchange-code
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# EU endpoints (do not change unless your Zoho org is on a different DC)
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.eu
ZOHO_MAIL_BASE=https://mail.zoho.eu/api
